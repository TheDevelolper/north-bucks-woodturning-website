---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageContent from '../components/PageContent.astro';
import { getCollection } from 'astro:content';

const sections = await getCollection('sections');
sections.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="FAQs" description="Frequently asked questions about North Bucks Woodturning Club — membership, sessions, and woodturning in Milton Keynes." section="faqs">
  <PageContent sections={sections} />
</BaseLayout>