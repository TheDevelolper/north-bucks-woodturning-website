---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageContent from '../components/PageContent.astro';
import { getCollection } from 'astro:content';

const sections = await getCollection('sections');
sections.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Gallery" description="Browse woodturning projects from North Bucks Woodturning Club members in Milton Keynes." section="gallery">
  <PageContent sections={sections} />
</BaseLayout>