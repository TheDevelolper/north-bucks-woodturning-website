---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageContent from '../components/PageContent.astro';
import { getCollection } from 'astro:content';

const sections = await getCollection('sections');
sections.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Contact" description="Get in touch with North Bucks Woodturning Club — join us in Stony Stratford, Milton Keynes." section="contact">
  <PageContent sections={sections} />
</BaseLayout>