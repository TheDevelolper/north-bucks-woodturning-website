---
const { image, text } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<div class="parallax-break">
  <div class="parallax-inner" style={`background-image: url('${image || base + 'hero.jpg'}')`}></div>
  {text && <div class="parallax-overlay"><p class="parallax-text">{text}</p></div>}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const steps = [];
    for (let i = 0; i <= 1; i += 0.05) steps.push(i);

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const el = entry.target;
        const ratio = entry.intersectionRatio;
        const inner = el.querySelector('.parallax-inner');
        const overlay = el.querySelector('.parallax-overlay');
        if (inner) {
          inner.style.opacity = ratio;
          const zoom = 100 + (1 - ratio) * 20;
          inner.style.backgroundSize = `${zoom}%`;
        }
        if (overlay) overlay.style.opacity = ratio;
      });
    }, { threshold: steps });

    document.querySelectorAll('.parallax-break').forEach(el => obs.observe(el));
  });
</script>

<style is:global>
  .parallax-break {
    height: 60vh; min-height: 400px;
    position: relative; overflow: hidden;
  }
  .parallax-inner {
    position: absolute; inset: -20% 0;
    background-size: cover; background-position: center;
    background-repeat: no-repeat; background-attachment: fixed;
    opacity: 0; will-change: opacity, background-size;
    transition: opacity 0.15s ease, background-size 0.15s ease;
  }

  .parallax-overlay {
    position: absolute; inset: 0; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; will-change: opacity;
    transition: opacity 0.15s ease;
    background: rgba(0,0,0,0.35);
  }
  .parallax-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    color: #fff; text-align: center; max-width: 600px;
    user-select: none;
    text-shadow: 0 5px 10px rgba(0,0,0,0.6), 0 4px 40px rgba(0,0,0,0.4);
    padding: 0 2rem;
  }

  @media (max-width: 768px) {
    .parallax-break { height: 60vh; min-height: 350px; }
    .parallax-text { 
      font-size: 6vw; 
      text-shadow: 0 5px 5px rgba(0,0,0,0.9), 0 4px 40px rgba(0,0,0,0.4);
    }
    
  }
</style>
