---
const { content, base: baseUrl } = Astro.props;
const base = baseUrl;

const body = content.body || '';
const parts = body.split(/\n(?=### )/);
const introMd = parts[0] || '';

const details = parts.slice(1).map(part => {
  const lines = part.trim().split('\n');
  const heading = lines[0].replace(/^###\s+/, '');
  const bodyText = lines.slice(1).join('\n').trim();
  return { heading, body: bodyText };
});

import WoodDivider from '../components/WoodDivider.astro';
import Button from '../components/Button.astro';
import openingTimesRaw from '../content/sections/_opening-times.md?raw';
details.push({ heading: 'When', body: openingTimesRaw.trim() });

const address = details.find(d => d.heading === 'Where')?.body.replace(/\n/g, ', ') || '';

function mdToHtml(text: string) {
  return text.split(/\n\n+/).map(p => {
    p = p.trim();
    if (!p) return '';
    return `<p>${p.replace(/\n/g, '<br>')}</p>`;
  }).join('\n');
}
---

<section class="section section-dark" id={content.data.sectionType}>
  <div class="container">
    <div class="section-label">{content.data.title}</div>
    <WoodDivider />
    <div class="about-grid">
      <div class="about-text" data-animate="fade-left">
        <h2 class="section-title">{content.data.title}</h2>
        <Fragment set:html={mdToHtml(introMd)} />
      </div>
      <div class="about-details" data-stagger>
        {details.map(d => {
          const mapsUrl = d.heading === 'Where'
            ? `https://www.google.com/maps?q=${encodeURIComponent(d.body.replace(/<[^>]*>/g, '').replace(/\n/g, ' '))}`
            : null;
          const calIcsUrl = d.heading === 'When' ? base + 'nbwc-sessions.ics' : null;
          return (
            <div class="detail-card" data-animate>
              <h4>{d.heading}</h4>
              <Fragment set:html={mdToHtml(d.body)} />
              {mapsUrl && <Button href={mapsUrl} variant="primary" size="sm">Open in Google Maps</Button>}
              {calIcsUrl && <Button href={calIcsUrl} variant="primary" size="sm">Add to Calendar</Button>}

<script>
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.calendar-btn');
    if (!btn) return;
    e.preventDefault();
    const icsUrl = 'https://' + location.host + btn.getAttribute('href');
    if (/iphone|ipad|mac/i.test(navigator.userAgent)) {
      window.location.href = 'webcal://' + location.host + btn.getAttribute('href');
    } else {
      window.location.href = icsUrl;
    }
  });
</script>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style is:global>
  .about-grid {
    display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center;
  }
  .about-text p { color: rgba(227,221,213,0.7); margin-bottom: 1.2rem; font-size: 0.95rem; }
  .about-details {
    display: grid; gap: 1.5rem;
  }
  .detail-card {
    background: rgba(60,40,25,0.25); border: 1px solid rgba(166,124,82,0.1);
    border-radius: 12px; padding: 1.5rem;
    transition: all 0.3s;
  }
  .detail-card:hover {
    background: rgba(80,50,30,0.35); border-color: rgba(166,124,82,0.25);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .detail-card h4 { color: #c4956a; font-size: 1rem; font-weight: 600; margin-bottom: 0.3rem; }
  .detail-card p { color: rgba(227,221,213,0.6); font-size: 0.9rem; }
  .detail-card .btn { margin-top: 0.75rem; }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>


