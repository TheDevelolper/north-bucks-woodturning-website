---
const { content } = Astro.props;
import openingTimesRaw from '../content/sections/_opening-times.md?raw';
const openingLines = openingTimesRaw.trim().split('\n');
---

<section class="section section-dark" id="contact">
  <div class="container">
    <div class="section-label">{content.data.title}</div>
    <div class="contact-grid">
      <div class="contact-info">
        <h3>We'd love to hear from you</h3>
        <p>Whether you're interested in joining, have a question, or just want to find out more — get in touch.</p>
        <div class="contact-detail">
          <span class="icon">&#9906;</span>
          <p>York House Centre, London Road, Stony Stratford,<br>Milton Keynes MK11 1JQ</p>
        </div>
        {openingLines.map(line => (
          <div class="contact-detail">
            <span class="icon">&#128338;</span>
            <p>{line}</p>
          </div>
        ))}
      </div>
      <form class="contact-form" netlify>
        <input type="text" name="name" placeholder="Your Name" required>
        <input type="email" name="email" placeholder="Your Email" required>
        <textarea name="message" placeholder="Your Message" required></textarea>
        <button type="submit">Send Message</button>
      </form>
    </div>
  </div>
</section>

<div class="map-container section-dark">
  <div class="map-placeholder">
    <div class="address">York House Centre, London Road, Stony Stratford</div>
    <div class="sub">Milton Keynes MK11 1JQ</div>
  </div>
</div>

<style is:global>
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
  }
  .contact-info h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; color: #fff; margin-bottom: 1rem;
  }
  .contact-info p { color: rgba(232,230,227,0.55); margin-bottom: 0.8rem; font-size: 0.95rem; }
  .contact-info .contact-detail { display: flex; gap: 0.8rem; margin-bottom: 1.2rem; }
  .contact-info .contact-detail .icon { color: #a67c52; font-size: 1.1rem; min-width: 1.5rem; }
  .contact-info .contact-detail p { margin-bottom: 0; }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .contact-form input,
  .contact-form textarea {
    width: 100%; padding: 0.9rem 1.2rem; border-radius: 8px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    color: #e8e6e3; font-family: 'Inter', sans-serif; font-size: 0.9rem;
    transition: all 0.3s; outline: none;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: rgba(166,124,82,0.4); background: rgba(166,124,82,0.04);
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: rgba(232,230,227,0.3); }
  .contact-form textarea { min-height: 130px; resize: vertical; }
  .contact-form button {
    padding: 0.9rem 2rem; background: #a67c52; color: #fff; border: none;
    border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer;
    transition: background 0.3s; align-self: flex-start;
  }
  .contact-form button:hover { background: #b88d63; }

  .map-container {
    max-width: 1100px; margin: 0 auto; padding: 0 2rem 4rem;
  }
  .map-placeholder {
    border-radius: 12px; overflow: hidden;
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
    padding: 4rem 2rem; text-align: center; color: rgba(232,230,227,0.4);
  }
  .map-placeholder .address {
    color: #e8e6e3; font-size: 1.1rem; margin-bottom: 0.5rem;
  }
  .map-placeholder .sub { font-size: 0.9rem; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
