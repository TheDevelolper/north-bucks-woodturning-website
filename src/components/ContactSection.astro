---
const { content } = Astro.props;
import WoodDivider from '../components/WoodDivider.astro';
import Button from '../components/Button.astro';
import openingTimesRaw from '../content/sections/_opening-times.md?raw';
import { site } from '../data/site';
const openingLines = openingTimesRaw.trim().split('\n');
---

<section class="section section-dark" id="contact">
  <div class="container">
    <div class="section-label" data-animate>{content.data.title}</div>
    <WoodDivider />
    <div class="contact-grid">
      <div class="contact-info" data-animate="fade-left">
        <h3>We'd love to hear from you</h3>
        <p>Whether you're interested in joining, have a question, or just want to find out more — get in touch.</p>
        <div class="contact-detail">
          <span class="icon">&#9906;</span>
          <p>York House Centre, London Road, Stony Stratford,<br>Milton Keynes MK11 1JQ</p>
        </div>
        {openingLines.map(line => (
          <div class="contact-detail">
            <span class="icon">&#128338;</span>
            <p>{line}</p>
          </div>
        ))}
      </div>
      <div class="contact-social" data-animate="fade-right">
        <h3>Connect with us</h3>
        <div class="contact-detail">
          <span class="icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="1.1rem" height="1.1rem">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </span>
          <a href={`mailto:${site.email}`} class="contact-link">Send us an email</a>
        </div>
        <div class="contact-detail">
          <span class="icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="1.1rem" height="1.1rem">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </span>
          <a href={site.facebook} target="_blank" rel="noopener" class="contact-link">Follow us on Facebook</a>
        </div>
      <!--
      <form class="contact-form" netlify>
        <input type="text" name="name" placeholder="Your Name" required>
        <input type="email" name="email" placeholder="Your Email" required>
        <textarea name="message" placeholder="Your Message" required></textarea>
        <Button type="submit" variant="primary" size="md">Send Message</Button>
      </form>
      -->
    </div>
  </div>
</section>


<style is:global>
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
  }
  .contact-info h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; color: #fff; margin-bottom: 1rem;
  }
  .contact-info p { color: rgba(227,221,213,0.55); margin-bottom: 0.8rem; font-size: 0.95rem; }
  .contact-detail { display: flex; gap: 0.8rem; margin-bottom: 1.2rem; align-items: center; }
  .contact-detail .icon { color: #c4956a; font-size: 1.1rem; min-width: 1.5rem; display: flex; align-items: center; }
  .contact-detail p { margin-bottom: 0; }
  .contact-social h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; color: #fff; margin-bottom: 1rem;
  }
  .contact-social .contact-detail .icon { color: #c4956a; font-size: 1.1rem; min-width: 1.5rem; }
  .contact-link {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: #c4956a;
    text-decoration: none;
    transition: color 0.3s;
  }
  .contact-link:hover { color: #d4a87a; }
  .contact-detail .icon svg { display: block; }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .contact-form input,
  .contact-form textarea {
    width: 100%; padding: 0.9rem 1.2rem; border-radius: 8px;
    background: rgba(60,40,25,0.2); border: 1px solid rgba(166,124,82,0.1);
    color: #e3ddd5; font-family: 'Inter', sans-serif; font-size: 0.9rem;
    transition: all 0.3s; outline: none;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: rgba(166,124,82,0.4); background: rgba(60,40,25,0.3);
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: rgba(227,221,213,0.3); }
  .contact-form textarea { min-height: 130px; resize: vertical; }
  .contact-form .btn { align-self: flex-start; }

  .map-container {
    max-width: 1100px; margin: 0 auto; padding: 0 2rem 4rem;
  }
  .map-placeholder {
    border-radius: 12px; overflow: hidden;
    background: rgba(60,40,25,0.2); border: 1px solid rgba(166,124,82,0.1);
    padding: 4rem 2rem; text-align: center; color: rgba(227,221,213,0.4);
  }
  .map-placeholder .address {
    color: #e3ddd5; font-size: 1.1rem; margin-bottom: 0.5rem;
  }
  .map-placeholder .sub { font-size: 0.9rem; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
