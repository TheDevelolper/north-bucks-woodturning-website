---
import WoodDivider from '../components/WoodDivider.astro';
const { content } = Astro.props;

const body = content.body || '';
const links: { name: string; url: string; desc: string }[] = [];
const linkRegex = /-\s+\[([^\]]+)\]\(([^)]+)\)\s*[—–-]?\s*(.+)/g;
let m;
while ((m = linkRegex.exec(body)) !== null) {
  links.push({
    name: m[1],
    url: m[2],
    desc: m[3].trim(),
  });
}
---

<section class="section section-divider" id="links">
  <div class="container">
    <div class="section-label" data-animate>Resources</div>
    <WoodDivider />
    <h2 class="section-title" data-animate>Useful Links</h2>
    <p class="section-sub" data-animate>Trusted suppliers, associations, and resources for the woodturning community.</p>
    <div class="links-grid" data-stagger>
      {links.map(link => (
        <a href={link.url} target="_blank" rel="noopener" class="link-card" data-animate>
          <div>
            <div class="link-name">{link.name}</div>
            <div class="link-desc">{link.desc}</div>
          </div>
          <span class="link-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .links-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;
  }
  .link-card {
    background: rgba(60,40,25,0.2); border: 1px solid rgba(166,124,82,0.1);
    border-radius: 10px; padding: 1.2rem 1.5rem; text-decoration: none;
    display: flex; justify-content: space-between; align-items: center;
    transition: all 0.3s; color: #e3ddd5;
  }
  .link-card:hover {
    border-color: rgba(166,124,82,0.3); background: rgba(80,50,30,0.3);
    transform: translateX(4px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  .link-card .link-name { font-weight: 500; font-size: 0.95rem; }
  .link-card .link-desc { color: rgba(227,221,213,0.45); font-size: 0.8rem; }
  .link-card .link-arrow { color: #a67c52; font-size: 1.2rem; }
</style>
