---
const base = import.meta.env.BASE_URL;
---
<section class="hero" id="home">
  <video class="hero-video" autoplay muted loop playsinline poster={`${base}hero.jpg`}>
    <source src={`${base}videos/demonstration.mp4`} type="video/mp4">
  </video>
  <div class="hero-content">
    <div class="hero-badge">Est. 1990s</div>
    <h1>Craft. Creativity.<br>Community.</h1>
    <p>North Bucks Woodturning Club — sharing woodturning expertise, techniques, and camaraderie every Saturday in Stony Stratford.</p>
    <div class="hero-buttons">
      <a href="#about" class="btn btn-primary">Discover More</a>
      <a href="#contact" class="btn btn-outline">Join Us</a>
    </div>
  </div>
</section>

<style is:global>
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 8rem 2rem 6rem;
    user-select: none;
    position: relative; overflow: hidden;
  }
  .hero-video {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; z-index: 0;
  }
  .hero::after {
    content: ''; position: absolute; inset: 0; z-index: 1;
    background:
      radial-gradient(ellipse at 100% 100%, rgba(0,0,0,0.2) 0%, transparent 10%);
  }
  .hero::before {
    content: ''; position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(135deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.6) 100%);
  }
  .hero-content {
    position: relative; z-index: 3; max-width: 800px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.437);
  }
  .hero-badge {
    display: inline-block; padding: 0.4rem 1.2rem; border-radius: 100px;
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.5); color: #ffffff;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(4px);
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 700;
    line-height: 1.1; margin-bottom: 1rem;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
  }
  .hero p {
    font-size: 1.2rem; color: rgba(255,255,255,0.85);
    max-width: 620px; margin: 0 auto 2.5rem;
    font-weight: 400;
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
  }
  .hero-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn {
    padding: 0.85rem 2rem; border-radius: 6px; text-decoration: none;
    font-size: 0.9rem; font-weight: 500; transition: all 0.3s;
    display: inline-flex; align-items: center; gap: 0.5rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.35);
  }
  .btn-primary {
    background: #a67c52; color: #fff;
  }
  .btn-primary:hover { background: #b88d63; transform: translateY(-1px); box-shadow: 0 6px 24px rgba(0,0,0,0.45); }
  .btn-outline {
    border: none; color: #1a1816;
    background: #fff;
  }
  .btn-outline:hover { background: #e8e6e3; color: #1a1816; transform: translateY(-1px); box-shadow: 0 6px 24px rgba(0,0,0,0.45); }
</style>
