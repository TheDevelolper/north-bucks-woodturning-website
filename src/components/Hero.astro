---
import Button from '../components/Button.astro';
import { meetingDaysPhrase } from '../data/utils';
const base = import.meta.env.BASE_URL;
---
<section class="hero" id="home">
  <video class="hero-video" autoplay muted loop playsinline webkit-playsinline preload="auto" poster={`${base}video-bg.png`}>
    <source src={`${base}videos/demonstration.mp4`} type="video/mp4">
  </video>
  <div class="hero-content">
    <div class="hero-badge">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
        <circle cx="8" cy="8" r="6"/>
        <circle cx="8" cy="8" r="3"/>
        <path d="M8 2 L8 14" opacity="0.4"/>
        <path d="M2 8 L14 8" opacity="0.4"/>
      </svg>
      EST. 1990's
    </div>
    <h1>Craft. Creativity.<br>Community.</h1>
    <p>Sharing woodturning expertise, techniques, and camaraderie {meetingDaysPhrase()} in Stony Stratford.</p>
    <div class="hero-buttons">
      <Button href="#about" variant="primary" size="lg">Discover More</Button>
      <Button href="#contact" variant="outline" size="lg">Join Us</Button>
    </div>
  </div>
</section>

<style is:global>
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center; padding: 8rem 2rem 6rem;
    user-select: none;
    position: relative; overflow: hidden;
  }
  .hero-video {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; z-index: 0;
  }
  .hero::after {
    content: ''; position: absolute; inset: 0; z-index: 1;
    background:
      radial-gradient(ellipse at 100% 100%, rgba(60,30,10,0.3) 0%, transparent 30%);
  }
  .hero::before {
    content: ''; position: absolute; inset: 0; z-index: 2;
    background: linear-gradient(135deg, rgba(20,16,12,0.15) 0%, rgba(20,16,12,0.3) 50%, rgba(20,16,12,0.5) 100%);
  }
  .hero-content {
    position: relative; z-index: 3; max-width: 800px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 1.0);
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 6vw, 5rem); font-weight: 700;
    line-height: 1.1; margin-bottom: 1rem;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1.2rem; border-radius: 100px;
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em;
    border: 1px solid rgba(166,124,82,0.4); color: #c4956a;
    background: rgba(20,16,12,0.6);
    backdrop-filter: blur(4px);
    margin-bottom: 1.5rem;
  }
  .hero p {
    font-size: 1.2rem; color: rgba(227,221,213,0.85);
    max-width: 620px; margin: 0 auto 2.5rem;
    font-weight: 400;
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
  }
  .hero-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
